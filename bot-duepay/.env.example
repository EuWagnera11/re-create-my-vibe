# ===== Site Lovable =====
SITE_URL=https://seu-app.lovable.app
BOT_TOKEN=troque-por-um-token-seguro-32-chars
BOT_ID=loja-pc-01
POLL_INTERVAL=3
HEARTBEAT_INTERVAL=30

# Paths das server functions (descubra no Network tab do DevTools)
PATH_NEXT_ORDER=/_serverFn/getNextOrder
PATH_REPORT=/_serverFn/reportOrder
PATH_HEARTBEAT=/_serverFn/heartbeat

# ===== TLN =====
TLN_LOGIN_URL=https://www1.tln.com.br/apps/ecommerce/autenticacao/login
TLN_LINK_PAGE=https://www1.tln.com.br/apps/ecommerce/transacaolink/index
TLN_USERNAME=seu-usuario-aqui
TLN_PASSWORD=sua-senha-aqui
TLN_HEADLESS=true
TLN_SLOW_MO=0
TLN_TIMEOUT=15

# Operadora padrão
DEFAULT_OPERADORA=PERSONAL CARD POS-PAGO
# Email fallback se o cliente não informar
TLN_FALLBACK_EMAIL=

# ===== Selectors do TLN =====

# --- LOGIN (já mapeado) ---
SEL_USERNAME=input[name="loginCpfCnpj"]
SEL_PASSWORD=input[name="senha"]
SEL_LOGIN_BTN=input[value="Logar"]

# --- FORM "GERAR LINK" (já mapeado) ---
SEL_OPERADORA=select[name="operadora"]
SEL_VALOR=input[name="valor"]
SEL_CONDICAO=select[name="condicao"]
SEL_EMAIL_CONFIRMACAO=input[name="emailConfirmacao"]
SEL_EMAIL_LINK=input[name="emailLink"]
SEL_CODIGO_PEDIDO=input[name="codigoPedido"]
SEL_GERAR_BTN=input[value="Gerar link de transação"]
SEL_RESULT_LINK=

# --- TELA DE PAGAMENTO (depois de clicar no link gerado) ---
# IMPORTANTE: essa tela NÃO tem campo de CPF
# Só tem: Número do cartão + Senha do cartão + botão "Confirmar Transação"
# Use o discover_selectors.py (IA) OU F12 pra mapear os name= reais

# Provavelmente: input[name*="cartao" i] ou input[name*="numeroCartao" i]
SEL_PAYMENT_CARD=input[name*="cartao" i], input[name*="numero" i]
# Provavelmente: input[name*="senha" i] ou input[type="password"]
SEL_PAYMENT_PIN=input[name*="senha" i], input[type="password"]
# Botão "Confirmar Transação"
SEL_PAYMENT_SUBMIT=input[value="Confirmar Transação"], button:has-text("Confirmar Transação")
# Onde aparece "Aprovado" / "Recusado" depois do submit
SEL_PAYMENT_RESULT=.alert, .message, .resultado, [class*="result" i], [class*="status" i]
# Onde aparece o NSU (se houver) - geralmente na tela de resultado
SEL_PAYMENT_NSU=[class*="nsu" i], [class*="autorizacao" i], [class*="protocolo" i]

# Palavras-chave pra detectar aprovado/recusado (fallback se IA falhar)
APPROVED_KEYWORDS=aprovado,autorizado,confirmado,success,sucesso,pago
REJECTED_KEYWORDS=recusado,rejeitado,negado,denied,failed,falha,inválido,insuficiente

# ===== OpenAI (IA) =====
# ⚠️ PEGA A KEY NO PAINEL: https://platform.openai.com/api-keys
# ⚠️ RECOMENDO LIMITE DE GASTO: $5-10/mês (uns 500-1000 pedidos)
# ⚠️ NUNCA COMMITA ESSE ARQUIVO COM A KEY
OPENAI_API_KEY=sk-proj-XXXXX-troque-pela-sua-key-real
OPENAI_MODEL=gpt-4o
# Se false, usa só o keyword matching (mais barato mas menos preciso)
USE_AI_FOR_RESULT=true
